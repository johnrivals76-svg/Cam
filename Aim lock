    OpenMenuButton.Parent = ScreenGui

    OpenMenuButton.MouseButton1Click:Connect(toggleMenuVisibility)
end

function toggleMenuVisibility()
    menuOpen = not menuOpen
    MenuFrame.Visible = menuOpen
end

local function isWithinFOV(targetPart)
    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
    if not onScreen then return false end

    local pixelPos = Vector2.new(screenPos.X * Camera.ViewportSize.X, screenPos.Y * Camera.ViewportSize.Y)
    local centerPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local distance = (pixelPos - centerPos).Magnitude

    return distance < FOV_RADIUS
end

-- === ESP FUNCTIONS (RAINBOW + WALL VISIBLE) ===
local function removeCurrentESP()
    if currentHighlight then
        currentHighlight:Destroy()
        currentHighlight = nil
    end
end

local function applyESPToTarget(character)
    removeCurrentESP() -- Remove old ESP first

    local Highlight = Instance.new("Highlight")
    Highlight.Name = "TargetESP"
    Highlight.Adornee = character -- Apply to whole character
    Highlight.FillTransparency = ESP_TRANSPARENCY
    Highlight.OutlineTransparency = 0
    -- This makes it visible even if they are behind walls/objects
    Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
    Highlight.Parent = character

    currentHighlight = Highlight -- Save it so we can update colors
end

-- This runs every frame to make the colors change (Rainbow Effect)
local function updateRainbowEffect(deltaTime)
    if currentHighlight then
        hue = (hue + deltaTime * RAINBOW_SPEED) % 1
        local rainbowColor = Color3.fromHSV(hue, 1, 1) -- Convert to RGB color
        currentHighlight.FillColor = rainbowColor
        currentHighlight.OutlineColor = rainbowColor
    end
end
-- === END OF ESP FUNCTIONS ===

function toggleLock()
    isLocked = not isLocked
    if not isLocked then
        removeCurrentESP() -- Remove ESP when turning off
        targetPlayer = nil
        ToggleButton.Text = "Aim Lock: OFF"
        ToggleButton.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
    else
        local closestDist = math.huge
        local myChar = LocalPlayer.Character
        if not myChar then 
            isLocked = false
            return 
        end

        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local targetPart = player.Character:FindFirstChild(LOCK_ON_PART)
                if targetPart and isWithinFOV(targetPart) then
                    local dist = (myChar.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        targetPlayer = player
                    end
                end
            end
        end

        -- Apply ESP immediately if we found a target
        if targetPlayer and targetPlayer.Character then
            applyESPToTarget(targetPlayer.Character)
        end

        ToggleButton.Text = "Aim Lock: ON"
        ToggleButton.BackgroundColor3 = Color3.new(0, 0.8, 0)
    end
end

local function onInputBegan(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.M then
        toggleMenuVisibility()
    end

    if input.KeyCode == Enum.KeyCode.F then
        toggleLock()
    end
end

UserInputService.InputBegan:Connect(onInputBegan)

-- Connect the rainbow color updater to the game loop
RunService.RenderStepped:Connect(updateRainbowEffect)

-- MAIN AIM LOGIC
RunService.RenderStepped:Connect(function()
    if isLocked and targetPlayer and targetPlayer.Character then
        -- Always tracks the Head, follows if they move
        local targetPart = targetPlayer.Character:FindFirstChild(LOCK_ON_PART)
        
        if targetPart and isWithinFOV(targetPart) then
            -- Make sure ESP is still there (fixes if character respawns)
            if not currentHighlight or currentHighlight.Adornee ~= targetPlayer.Character then
                applyESPToTarget(targetPlayer.Character)
            end

            -- Move aim smoothly
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.new(Camera.CFrame.Position, targetPart.Position),
                LERP_SPEED
            )
        else
            removeCurrentESP() -- Remove if they go out of FOV
        end
    else
        removeCurrentESP() -- Safety remove if nothing is locked
    end
end)

-- NO AUTO FIRE: There is zero code here that presses buttons or fires weapons.

createMenu()
