    Title.TextColor3 = Color3.new(1, 1, 1)
    Title.Font = Enum.Font.GothamBold
    Title.TextScaled = true
    Title.Parent = MenuFrame

    ToggleButton = Instance.new("TextButton")
    ToggleButton.Name = "ToggleFeature"
    ToggleButton.Size = BUTTON_SIZE
    ToggleButton.Position = UDim2.new(0.1, 0, 0.3, 0)
    ToggleButton.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
    ToggleButton.Text = "Aim Lock: OFF"
    ToggleButton.TextColor3 = Color3.new(1, 1, 1)
    ToggleButton.Font = Enum.Font.Gotham
    ToggleButton.TextScaled = true
    ToggleButton.Parent = MenuFrame

    ToggleButton.MouseButton1Click:Connect(toggleLock)

    local OpenMenuButton = Instance.new("TextButton")
    OpenMenuButton.Name = "OpenMenuButton"
    OpenMenuButton.Size = UDim2.new(0, 100, 0, 40)
    OpenMenuButton.Position = UDim2.new(0.05, 0, 0.92, 0)
    OpenMenuButton.BackgroundColor3 = Color3.new(1, 0, 0)
    OpenMenuButton.Text = "Open Menu"
    OpenMenuButton.TextColor3 = Color3.new(1, 1, 1)
